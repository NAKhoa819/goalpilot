
-- 1. Bảng goals: Lưu trữ các mục tiêu tài chính
CREATE TABLE goals (
    id VARCHAR(50) PRIMARY KEY,
    name NVARCHAR(255) NOT NULL,
    type VARCHAR(50) NOT NULL,
    target_amount DECIMAL(15,2) NOT NULL,
    target_date DATE NOT NULL,
    current_saved DECIMAL(15,2) DEFAULT 0,
    currency VARCHAR(10) DEFAULT 'VND',
    status VARCHAR(50) DEFAULT 'on_track',
    created_at DATETIME DEFAULT GETDATE()
);

-- 2. Bảng chat_sessions: Lưu thông tin phiên chat với AI
CREATE TABLE chat_sessions (
    id VARCHAR(50) PRIMARY KEY,
    created_at DATETIME DEFAULT GETDATE()
);

-- 3. Bảng chat_messages: Lưu chi tiết từng câu nhắn
CREATE TABLE chat_messages (
    id VARCHAR(50) PRIMARY KEY,
    session_id VARCHAR(50) NOT NULL,
    role VARCHAR(20) NOT NULL,
    text NVARCHAR(MAX) NOT NULL, 
    created_at DATETIME DEFAULT GETDATE(),
    FOREIGN KEY (session_id) REFERENCES chat_sessions(id)
);

-- 4. Bảng transactions: Lưu lịch sử dòng tiền 
CREATE TABLE transactions (
    id INT IDENTITY(1,1) PRIMARY KEY, 
    transaction_date DATE NOT NULL,
    amount DECIMAL(15,2) NOT NULL,
    type VARCHAR(20) NOT NULL,
    category VARCHAR(100),
    description NVARCHAR(MAX),
    is_essential BIT DEFAULT 0, 
    source VARCHAR(50),
    goal_id VARCHAR(50),
    created_at DATETIME DEFAULT GETDATE(),
    FOREIGN KEY (goal_id) REFERENCES goals(id)
);
