# Frontend
EXPO_PUBLIC_API_URL=http://<YOUR_MACHINE_IP>:8000

# Backend LLM
ACTIVE_LLM_PROVIDER=backup
BACKUP_PROVIDER=gemini
BACKUP_MODEL_ID=gemini-1.5-flash
GROQ_API_KEY=your_groq_api_key
GOOGLE_API_KEY=your_google_api_key
BEDROCK_MODEL=bedrock/anthropic.claude-3-5-sonnet-20240620-v1:0

# Backend SageMaker car price prediction
SAGEMAKER_REGION=us-west-2
SAGEMAKER_CAR_PRICE_ENDPOINT_NAME=your-sagemaker-endpoint-name
SAGEMAKER_CAR_PRICE_CONTENT_TYPE=text/csv
SAGEMAKER_CAR_PRICE_ACCEPT=text/csv
SAGEMAKER_CAR_PRICE_REQUEST_FORMAT=csv
CAR_PRICE_MODEL_REFERENCE_YEAR=2026
CAR_PRICE_MODEL_OUTPUT_MULTIPLIER_VND=28100000
AWS_PROFILE=
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-west-2

# Backend SQL Server
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=swinhackathon_db
DB_DRIVER={ODBC Driver 17 for SQL Server}
DB_TRUSTED_CONNECTION=yes
DB_USER=
DB_PASSWORD=
DB_TRUST_SERVER_CERTIFICATE=yes
DB_ENCRYPT=no
DB_SEED_DEFAULT_GOALS=no

# Backend dev/testing override
# Leave empty for normal behavior. Set to A, B, or None to force strategy in dev.
FORCE_STRATEGY=

# Docker SQL Server
SQLSERVER_SA_PASSWORD=YourStrong!Passw0rd
